{
  "rules": {
    "rooms": {
      "$roomCode": {
        ".read":  "auth != null",
        ".write": "auth != null",
        "answers": {
          "$qIdx": {
            "$userId": {
              ".write": "auth != null && auth.uid == $userId && !data.exists()"
            }
          }
        },
        "reveal_locks": {
          "$qIdx": {
            ".read":  "auth != null",
            ".write": "auth != null && !data.exists()"
          }
        },
        "next_locks": {
          "$qIdx": {
            ".read":  "auth != null",
            ".write": "auth != null && !data.exists()"
          }
        }
      }
    },
    "host_rooms": {
      "$hostId": {
        ".read":  "auth != null && auth.uid == $hostId",
        ".write": "auth != null && auth.uid == $hostId"
      }
    },
    "duels": {
      "$duelId": {
        ".read":  "auth != null",
        ".write": "auth != null",
        "answers": {
          "$qIdx": {
            "$userId": {
              ".write": "auth != null",
              "selected_choice": {
                ".validate": "!data.exists() ? (newData.isNumber() && auth.uid == $userId) : newData.val() == data.val()"
              },
              "reaction_time_ms": {
                ".validate": "!data.exists() ? (newData.isNumber() && newData.val() >= 50 && newData.val() <= 65000 && auth.uid == $userId) : newData.val() == data.val()"
              },
              "uid": {
                ".validate": "newData.isString() && newData.val() == auth.uid"
              }
            }
          }
        },
        "players": {
          "$uid": {
            "score": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= (data.exists() ? data.val() + 2 : 2)"
            }
          }
        }
      }
    },
    "duel_queue": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },
    "duel_presence": {
      "$duelId": {
        "$uid": {
          ".read":  "auth != null",
          ".write": "auth != null && auth.uid == $uid"
        }
      }
    },
    "tournament_registrations": {
      "$tournamentId": {
        ".read":  "auth != null",
        ".write": "auth != null"
      }
    },
    "tournament_duels": {
      "$tournamentId": {
        "$duelId": {
          ".read":  "auth != null",
          ".write": "auth != null",
          "answers": {
            "$qIdx": {
              "$userId": {
                ".write": "auth != null",
                "selected_choice": {
                  ".validate": "!data.exists() ? (newData.isNumber() && auth.uid == $userId) : newData.val() == data.val()"
                },
                "reaction_time_ms": {
                  ".validate": "!data.exists() ? (newData.isNumber() && newData.val() >= 50 && newData.val() <= 65000 && auth.uid == $userId) : newData.val() == data.val()"
                },
                "uid": {
                  ".validate": "newData.isString() && newData.val() == auth.uid"
                }
              }
            }
          },
          "players": {
            "$uid": {
              "score": {
                ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= (data.exists() ? data.val() + 2 : 2)"
              }
            }
          },
          "forfeit_by": {
            ".validate": "newData.isString() && newData.val() == auth.uid"
          },
          "surrender_by": {
            ".validate": "newData.isString() && newData.val() == auth.uid"
          }
        }
      }
    },
    "tournament_presence": {
      "$tournamentId": {
        "$uid": {
          ".read":  "auth != null",
          ".write": "auth != null && auth.uid == $uid"
        }
      }
    },
    "tournament_meta": {
      "$tournamentId": {
        ".read":  "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
