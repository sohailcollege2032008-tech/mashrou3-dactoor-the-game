{
  "rules": {
    "rooms": {
      "$roomCode": {
        ".read":  "auth != null",
        ".write": "auth != null",
        "answers": {
          "$qIdx": {
            "$userId": {
              ".write": "auth != null && auth.uid == $userId && !data.exists()"
            }
          }
        },
        "reveal_locks": {
          "$qIdx": {
            ".read":  "auth != null",
            ".write": "auth != null && !data.exists()"
          }
        },
        "next_locks": {
          "$qIdx": {
            ".read":  "auth != null",
            ".write": "auth != null && !data.exists()"
          }
        }
      }
    },
    "host_rooms": {
      "$hostId": {
        ".read":  "auth != null && auth.uid == $hostId",
        ".write": "auth != null && auth.uid == $hostId"
      }
    },
    "duels": {
      "$duelId": {
        ".read":  "auth != null",
        ".write": "auth != null"
      }
    },
    "duel_queue": {
      ".read":  "auth != null",
      ".write": "auth != null"
    },
    "duel_presence": {
      "$duelId": {
        "$uid": {
          ".read":  "auth != null",
          ".write": "auth != null && auth.uid == $uid"
        }
      }
    }
  }
}
