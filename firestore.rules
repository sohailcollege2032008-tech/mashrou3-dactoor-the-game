rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /profiles/{userId} {
      // Any logged-in user can read profiles (for public profile pages)
      allow read: if request.auth != null;
      // Only the profile owner can write their own profile
      allow write: if request.auth.uid == userId;

      // Game history subcollection — readable by anyone, writable by owner only
      match /game_history/{entryId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == userId;
      }

      // Played questions per deck — readable by ANY authenticated user so that
      // the opponent can fetch the other player's history for combined exclusion.
      // Only the owner can write their own played questions.
      match /played_questions/{deckId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == userId;
      }
    }

    match /question_sets/{setId} {
      allow read: if request.auth != null;
      // Anyone can create a question set (hosts upload their own decks)
      allow create: if request.auth != null;
      // Only the deck creator or the platform owner can update or delete
      allow update, delete: if request.auth != null && (
        resource.data.host_id == request.auth.uid ||
        request.auth.token.email == 'sohailcollege2032008@gmail.com'
      );
    }

    match /authorized_hosts/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null &&
                      request.auth.token.email == 'sohailcollege2032008@gmail.com';
    }

    // Notifications — any authenticated user can write to any user's notifications
    // (needed so player clients can write host notifications in unattended mode,
    //  and so the host can write player notifications).
    // Only the notification owner can read their own notifications.
    match /notifications/{userId}/items/{notifId} {
      allow read:  if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null;
    }

    // Tournaments — readable by any auth user (players need to read to join/follow).
    match /tournaments/{tournamentId} {
      allow read: if request.auth != null;
      // Anyone (host) can create a new tournament
      allow create: if request.auth != null;
      // Only the tournament host or platform owner can update/delete the tournament doc
      allow update, delete: if request.auth != null && (
        resource.data.host_id == request.auth.uid ||
        request.auth.token.email == 'sohailcollege2032008@gmail.com'
      );

      // Registrations subcollection — player writes their own entry; host reads all.
      match /registrations/{uid} {
        allow read:  if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // FFA results written by the host game runner after FFA ends.
      // Only the tournament host or platform owner can write.
      match /ffa_results/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && (
          get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.host_id == request.auth.uid ||
          request.auth.token.email == 'sohailcollege2032008@gmail.com'
        );
      }

      // Bracket matches — created/deleted by host; updated by host or the two participants.
      match /bracket_matches/{matchId} {
        allow read: if request.auth != null;
        allow create, delete: if request.auth != null && (
          get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.host_id == request.auth.uid ||
          request.auth.token.email == 'sohailcollege2032008@gmail.com'
        );
        allow update: if request.auth != null && (
          get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.host_id == request.auth.uid ||
          request.auth.token.email == 'sohailcollege2032008@gmail.com' ||
          request.auth.uid == resource.data.player_a_uid ||
          request.auth.uid == resource.data.player_b_uid
        );
      }
    }
  }
}
