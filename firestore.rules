rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the requester the owner role?
    function isOwner() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'owner';
    }

    // Profiles — users read/write their own; owner can read all
    match /profiles/{userId} {
      allow read:  if request.auth != null && (request.auth.uid == userId || isOwner());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Authorized hosts — any auth user can read (needed to check host status on login)
    // Only owner can add/remove hosts
    match /authorized_hosts/{docId} {
      allow read:  if request.auth != null;
      allow write: if isOwner();
    }

    // Question sets — hosts CRUD their own banks only
    match /question_sets/{docId} {
      allow read, update, delete: if request.auth != null &&
                                     resource.data.host_id == request.auth.uid;
      allow create: if request.auth != null &&
                       request.resource.data.host_id == request.auth.uid;
    }
  }
}
